    text-align: center;
    color: var(--color-leaf);
    margin-bottom: 2rem;
  }

  .about-intro {
    max-width: 700px;
    margin: 0 auto 3rem;
    text-align: center;
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .about-features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .feature {
    text-align: center;
    padding: 1.5rem;
  }

  .feature h3 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: var(--color-bark);
    margin-bottom: 0.75rem;
  }

  .feature p {
    font-size: 0.95rem;
    color: var(--color-moss);
  }

  .about-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }

  .about-tags span {
    background: var(--color-cream);
    border: 1px solid var(--color-gold);
    color: var(--color-bark);
    padding: 0.4rem 1rem;
    border-radius: 999px;
    font-size: 0.85rem;
  }

  .about-cta {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 500;
    transition: all 0.2s;
    background: var(--color-sand);
    color: white;
  }

  .btn:hover {
    background: var(--color-gold);
    color: white;
  }

  .btn-outline {
    background: transparent;
    border: 2px solid var(--color-sand);
    color: var(--color-sand);
  }

  .btn-outline:hover {
    background: var(--color-sand);
    color: white;
  }

  .about-note {
    text-align: center;
    font-size: 0.85rem;
    color: var(--color-moss);
    max-width: 500px;
    margin: 0 auto 3rem;
  }

  .about-cn {
    max-width: 600px;
    margin: 0 auto;
    padding: 2rem;
    background: var(--color-cream);
    border-radius: 12px;
    border-left: 4px solid var(--color-gold);
  }

  .about-cn h3 {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--color-bark);
    margin-bottom: 1rem;
  }

  .about-cn p {
    font-size: 0.95rem;
    line-height: 1.9;
    margin-bottom: 0.75rem;
    color: var(--color-leaf);
  }
</style>
