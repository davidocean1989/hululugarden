---
const INSTAGRAM_HANDLE = "hululu_garden";
---

<section id="instagram" class="instagram-feed">
  <div class="container">
    <h2 class="section-title">Follow Us on Instagram</h2>
    <p class="feed-intro">
      Fresh from the workshop — new gourds, market days, and behind-the-scenes moments.
      Follow <a href="https://www.instagram.com/{INSTAGRAM_HANDLE}/" target="_blank" rel="noopener noreferrer">@{INSTAGRAM_HANDLE}</a> for more.
    </p>

    <div class="feed-grid" id="insta-feed">
      <!-- Elfsight Instagram Feed Widget will render here -->
      <div class="elfsight-app-329da65b-1ac8-4cfb-8e35-8586373488ea" data-elfsight-app-lazy></div>
    </div>

    <div class="feed-cta">
      <a href="https://www.instagram.com/{INSTAGRAM_HANDLE}/" target="_blank" rel="noopener noreferrer" class="btn btn-insta">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" style="margin-right:6px;vertical-align:middle">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
        </svg>
        See more on Instagram
      </a>
    </div>
  </div>
</section>

<!-- Elfsight SDK -->
<script src="https://elfsightcdn.com/platform.js" async></script>

<style>
  .instagram-feed {
    padding: 5rem 0;
    background: var(--color-warm);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    text-align: center;
    color: var(--color-leaf);
    margin-bottom: 1rem;
  }

  .feed-intro {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 3rem;
    font-size: 0.95rem;
    color: var(--color-moss);
  }

  .feed-intro a {
    font-weight: 500;
    color: var(--color-sand);
  }

  .feed-grid {
    min-height: 200px;
    margin-bottom: 2rem;
    width: 100%;
  }

  .feed-cta {
    text-align: center;
  }

  .btn-insta {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.8rem;
    border-radius: 50px;
    background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
    color: #fff;
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .btn-insta:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(225, 48, 108, 0.35);
    color: #fff;
  }
</style>

<style is:global>
  /* Force Elfsight widget centered */
  .feed-grid .eapps-instagram-feed {
    width: 100% !important;
    max-width: 1100px !important;
    margin: 0 auto !important;
  }

  .feed-grid [class*="elfsight-app"] {
    width: 100% !important;
    margin: 0 auto !important;
  }

  .feed-grid .eapps-instagram-feed-posts {
    justify-content: center !important;
  }

  /* Hide Elfsight free plan branding */
  .feed-grid [class*="eapps-instagram-feed-promo"],
  .feed-grid [class*="Free"],
  .feed-grid a[href*="elfsight.com"],
  .feed-grid .eapps-instagram-feed-promo-link,
  .feed-grid div[class*="promo"] {
    display: none !important;
    visibility: hidden !important;
    height: 0 !important;
    overflow: hidden !important;
  }
</style>
