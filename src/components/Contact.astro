<section id="contact" class="contact">
  <div class="container">
    <h2 class="section-title">Get in Touch</h2>
    <p class="contact-intro">
      Have a custom idea, wholesale inquiry, or want us at your market or event?
      Send us a note – we'd love to hear from you.
    </p>

    <div class="contact-method">
      <h3>Email</h3>
      <p>The best way to reach us is by email. Please include a short description of
      what you have in mind and any deadline you're working with.</p>
      <a href="mailto:david.a.ocean@gmail.com" class="email-link">
        david.a.ocean@gmail.com
      </a>
    </div>
  </div>
</section>

<style>
  .contact {
    padding: 4rem 0;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    text-align: center;
    color: var(--color-leaf);
    margin-bottom: 1rem;
  }

  .contact-intro {
    text-align: center;
    max-width: 500px;
    margin: 0 auto 3rem;
    font-size: 0.95rem;
    color: var(--color-moss);
  }

  .contact-method {
    text-align: center;
    max-width: 500px;
    margin: 0 auto;
    padding: 2rem;
    background: var(--color-warm);
    border-radius: 12px;
  }

  .contact-method h3 {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--color-bark);
    margin-bottom: 0.75rem;
  }

  .contact-method p {
    font-size: 0.9rem;
    color: var(--color-moss);
    margin-bottom: 1rem;
  }

  .email-link {
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--color-sand);
  }
</style>
